{
  "name": "maimoni",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "sst": "sst --stage $STAGE",
    "env": "bun --env-file=.env",
    "test:all": "bun --env-file=.env test --timeout 120000 && bun run --cwd packages/db test:integration && bun run --cwd apps/webapp test && bun run --cwd apps/webapp test:e2e",
    "check": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "dev": "bun run --filter '*' dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.1",
    "@types/aws-lambda": "8.10.160",
    "@types/bun": "latest",
    "ion": "^1.0.1",
    "lucide-react": "^0.564.0",
    "patch-package": "^8.0.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "packageManager": "bun@1.0.0+",
  "dependencies": {
    "sst": "^3.18.5"
  },
  "patchedDependencies": {
    "@openauthjs/openauth@0.4.3": "patches/@openauthjs%2Fopenauth@0.4.3.patch"
  }
}
