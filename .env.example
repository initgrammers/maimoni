# =============================================================================
# REQUIRED - Basic app functionality won't work without these
# =============================================================================

# Database
# NOTE: Currently only Neon PostgreSQL is supported by our connector
# Get your connection string at: https://console.neon.tech/
# Format: postgresql://user:password@host-pooler.neon.tech/db?sslmode=require
DATABASE_URL='postgresql://user:password@host-pooler.neon.tech/neondb?sslmode=require'

# Auth Service
# Storage configuration for OpenAuth sessions
# "memory" for local dev (persisted to file), "dynamo" for production
AUTH_STORAGE=`{"type":"memory","options":{"persist": "./persist.json"}}`

# Auth service URL - used by API to verify tokens
# In local dev, this matches the auth service port (3002 by default in SST)
AUTH_URL='http://localhost:3002/auth'

# API Service
# Base URL for the API endpoints
# Used by the webapp to make API calls
API_URL='http://localhost:3001/api'

# =============================================================================
# OPTIONAL - Required only for specific features
# =============================================================================

# AI Services - Required for receipt scanning feature
# If left as fake values, receipt scanning will fail
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY='fake_groq_key'

# Get your key at: https://cloud.llamaindex.ai/api-key
LLAMA_CLOUD_API_KEY='fake_llama_key'

# Twilio - Required for WhatsApp/SMS authentication
# If left as fake values, auth via WhatsApp/SMS won't work (other auth methods may still work)
# Get your credentials at: https://console.twilio.com/
TWILIO_ACCOUNT_SID='fake_account_sid'
TWILIO_AUTH_TOKEN='fake_auth_token'

# Twilio phone numbers
# Format for WhatsApp: whatsapp:+1234567890
# Format for SMS: +1234567890
TWILIO_WHATSAPP_NUMBER='whatsapp:+1234567890'
TWILIO_PHONE_NUMBER='+1234567890'

# =============================================================================
# SST / AWS - Required only if using SST for development or deployment
# =============================================================================

# Stage for SST - controls the environment and resource naming
# Use 'dev-yourname' for local development (e.g., 'dev-juan', 'dev-maria')
# Use 'staging' for staging environment
# Use 'production' for production deployment
STAGE='dev-yourname'

# AWS credentials - required for SST to create/manage AWS resources
# Get your credentials at: https://console.aws.amazon.com/iam/home#/security_credentials
AWS_ACCESS_KEY_ID='your_aws_access_key'
AWS_SECRET_ACCESS_KEY='your_aws_secret_key'
AWS_REGION='us-east-1'  # Optional: defaults to 'us-east-1' if not set

# =============================================================================
# NOTES FOR LOCAL DEVELOPMENT
# =============================================================================
# 
# MINIMUM SETUP (for basic testing):
# - DATABASE_URL (real Neon database)
# - AUTH_STORAGE, AUTH_URL, API_URL (can use values above)
# - GROQ_API_KEY, LLAMA_CLOUD_API_KEY, TWILIO_* (can be fake - features disabled)
#
# FULL SETUP (all features working):
# - All variables above must have real values
# - Sign up for: Neon (DB), Groq (AI), LlamaCloud (AI), Twilio (Auth)
#
# SST SETUP (if using SST for dev/deploy):
# - Configure STAGE (use 'dev-yourname' for local dev)
# - Add AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY
# - Run: bun env sst dev (instead of bun env dev)
#
# DEFAULT SST PORTS:
# - Auth service: 3002
# - API service: 3001
# - Webapp: 3000
#
# IMPORTANT: Always use 'bun env' prefix to load .env variables:
# - bun env dev              # Basic mode
# - bun env sst dev          # SST mode
# - bun env --filter='@maimoni/db' db:migrate  # DB commands
#
